<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AutoBrr Filter Gen</title>
    <style>
        :root { --primary: #3e5cf4; --bg: #f8f9fa; --card-bg: #ffffff; }
        body { font-family: -apple-system, system-ui, sans-serif; background: var(--bg); display: flex; justify-content: center; padding: 40px 20px; margin: 0; }
        .card { background: var(--card-bg); width: 100%; max-width: 850px; padding: 30px; border-radius: 16px; box-shadow: 0 10px 25px rgba(0,0,0,0.05); box-sizing: border-box; }
        .input-group { display: flex; gap: 10px; margin-bottom: 20px; }
        input { flex-grow: 1; padding: 12px; border: 2px solid #eee; border-radius: 8px; font-size: 16px; outline: none; min-width: 0; }
        button { padding: 12px 24px; cursor: pointer; background: var(--primary); color: white; border: none; border-radius: 8px; font-weight: 600; transition: opacity 0.2s; white-space: nowrap; }
        button:disabled { opacity: 0.6; cursor: not-allowed; }
        #copyBtn { background: #28a745; margin-top: 10px; width: 100%; display: none; }
        textarea { width: 100%; height: 350px; margin-top: 15px; padding: 15px; border: 1px solid #ddd; border-radius: 8px; font-family: monospace; font-size: 13px; background: #fafafa; box-sizing: border-box; }
        .status { font-size: 13px; font-weight: 600; margin-bottom: 10px; min-height: 20px; }
        .error { color: #dc3545; }
        @media (max-width: 600px) {
            .input-group { flex-direction: column; }
            button { width: 100%; }
        }
    </style>
</head>
<body>

<div class="card">
    <h1>AniList -> AutoBrr</h1>
    <div class="input-group">
        <input type="text" id="username" placeholder="AniList Username" autocomplete="username">
        <button id="generateBtn" onclick="generateFilter()">Generate</button>
    </div>
    <div id="status" class="status"></div>
    <textarea id="output" readonly placeholder="Filter will appear here..."></textarea>
    <button id="copyBtn" onclick="copyToClipboard()">Copy to Clipboard</button>
</div>

<script>
    const isEnglishFriendly = (str) => /^[\x00-\x7F]*$/.test(str);

    function safeGetItem(key) {
        try {
            return localStorage.getItem(key);
        } catch {
            return null;
        }
    }

    function safeSetItem(key, value) {
        try {
            localStorage.setItem(key, value);
        } catch {
            // Ignore storage failures in private/locked-down browsers.
        }
    }

    function foldCommonCharacters(value) {
        return String(value)
            .normalize("NFKD")
            .replace(/[\u0300-\u036f]/g, "")
            .replace(/[×✕✖]/g, " x ")
            .replace(/&/g, " and ")
            .replace(/\+/g, " plus ")
            .replace(/[‐‑‒–—―]/g, "-");
    }

    function toWildcardPattern(title) {
        const tokens = foldCommonCharacters(title)
            .toLowerCase()
            .match(/[a-z0-9]+/g);

        if (!tokens) return "";
        return tokens.join("*");
    }

    function addWildcardPattern(filterEntries, rawPattern) {
        const pattern = String(rawPattern || "").trim();
        if (!pattern) return;

        const compactLength = pattern.replace(/\*/g, "").length;
        if (compactLength <= 2) return;

        filterEntries.push(`*${pattern}*`);
    }

    function getSeasonInfo(cleanTitle) {
        const match = cleanTitle.match(/\b(season|part|cour)\s*(\d+)\b/i);
        if (!match) return null;

        const marker = match[1];
        const number = match[2];
        const rootTitle = cleanTitle.split(new RegExp(marker, "i"))[0].trim();

        if (!rootTitle || !number) return null;
        return { rootTitle, number };
    }

    // Auto-load username from previous visits
    document.addEventListener("DOMContentLoaded", () => {
        const savedName = safeGetItem('anilist_username');
        if (savedName) document.getElementById('username').value = savedName;

        document.getElementById('username').addEventListener('keydown', (event) => {
            if (event.key === 'Enter') generateFilter();
        });
    });

    async function generateFilter() {
        const usernameInput = document.getElementById('username');
        const username = usernameInput.value.trim();
        const status = document.getElementById('status');
        const output = document.getElementById('output');
        const copyBtn = document.getElementById('copyBtn');
        const generateBtn = document.getElementById('generateBtn');

        if (!username) {
            status.innerText = "Please enter an AniList username.";
            status.classList.add('error');
            return;
        }

        // Save username and update UI state
        safeSetItem('anilist_username', username);
        generateBtn.disabled = true;
        status.innerText = "Querying AniList...";
        status.classList.remove('error');
        output.value = "";
        copyBtn.style.display = "none";

        const query = `
        query ($name: String) {
          MediaListCollection(userName: $name, type: ANIME, status: CURRENT) {
            lists {
              entries {
                media {
                  id
                  title { romaji english }
                  synonyms
                }
              }
            }
          }
        }`;

        try {
            const response = await fetch('https://graphql.anilist.co', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'Accept': 'application/json'
                },
                body: JSON.stringify({ query, variables: { name: username } })
            });

            let result;
            try {
                result = await response.json();
            } catch {
                throw new Error(`AniList returned a non-JSON response. HTTP ${response.status}.`);
            }

            if (!response.ok) {
                const retryAfter = response.headers.get('Retry-After');
                const apiMessage = result?.errors?.map(error => error.message).join('; ');
                let message = apiMessage || `AniList returned HTTP ${response.status}.`;

                if (response.status === 429 && retryAfter) {
                    message += ` Retry after ${retryAfter} seconds.`;
                }

                throw new Error(message);
            }

            if (result.errors?.length) {
                throw new Error(result.errors.map(error => error.message).join('; '));
            }

            if (!result.data || !result.data.MediaListCollection) {
                throw new Error("User not found or list is private.");
            }

            const lists = Array.isArray(result.data.MediaListCollection.lists)
                ? result.data.MediaListCollection.lists
                : [];

            let filterEntries = [];
            const seenMediaIds = new Set();

            lists.forEach(list => {
                const entries = Array.isArray(list.entries) ? list.entries : [];

                entries.forEach(entry => {
                    const m = entry?.media;
                    if (!m) return;

                    if (m.id && seenMediaIds.has(m.id)) return;
                    if (m.id) seenMediaIds.add(m.id);

                    const coreTitles = [m.title?.romaji, m.title?.english].filter(Boolean);
                    const synonyms = Array.isArray(m.synonyms) ? m.synonyms : [];
                    const cleanSynonyms = synonyms.filter(s => s && isEnglishFriendly(s));
                    let allPossibleTitles = [...new Set([...coreTitles, ...cleanSynonyms])];

                    allPossibleTitles.forEach(name => {
                        let clean = String(name).toLowerCase();
                        let variants = [clean];

                        if (clean.includes('season ') || clean.includes('part ') || clean.includes('cour ')) {
                            const seasonInfo = getSeasonInfo(clean);

                            if (seasonInfo) {
                                const n = seasonInfo.number;
                                const suffix = (n === '1' ? 'st' : n === '2' ? 'nd' : n === '3' ? 'rd' : 'th');
                                const rootTitle = seasonInfo.rootTitle;

                                variants.push(`${rootTitle} ${n}`);
                                variants.push(`${rootTitle} ${n}${suffix} season`);
                                variants.push(`${rootTitle} season ${n}`);
                                variants.push(`${rootTitle} part ${n}`);
                            }
                        }

                        variants.forEach(v => {
                            addWildcardPattern(filterEntries, toWildcardPattern(v));
                        });
                    });
                });
            });

            const uniqueEntries = [...new Set(filterEntries)].sort();

            if (uniqueEntries.length === 0) {
                throw new Error("No usable title patterns were generated. Refusing to output an empty AutoBrr filter.");
            }

            const final = uniqueEntries.join(',');
            output.value = final;
            status.innerText = `Generated ${uniqueEntries.length} clean patterns! ${final.length.toLocaleString()} characters.`;
            copyBtn.style.display = "block";

        } catch (err) {
            status.innerText = "Error: " + (err?.message || "Unknown error.");
            status.classList.add('error');
        } finally {
            // Re-enable button regardless of success/fail
            generateBtn.disabled = false;
        }
    }

    async function copyToClipboard() {
        const output = document.getElementById('output');
        const btn = document.getElementById('copyBtn');

        try {
            if (!navigator.clipboard?.writeText) throw new Error("Clipboard API unavailable.");
            await navigator.clipboard.writeText(output.value);
        } catch {
            output.focus();
            output.select();
            document.execCommand('copy');
        }

        btn.innerText = "Copied!";
        setTimeout(() => { btn.innerText = "Copy to Clipboard"; }, 2000);
    }
</script>
</body>
</html>
