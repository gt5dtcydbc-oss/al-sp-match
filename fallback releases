<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Anime Releases Tracker</title>
  <style>
    :root {
      --bg: #0b1020;
      --bg-soft: #121933;
      --panel: #11182d;
      --panel-soft: #18213d;
      --card: #131b31;
      --text: #eef2ff;
      --muted: #98a6cc;
      --line: rgba(255,255,255,0.08);
      --line-strong: rgba(255,255,255,0.12);
      --accent: #8c9eff;
      --accent-soft: rgba(140,158,255,0.16);
      --ok: #4adea8;
      --ok-soft: rgba(74,222,168,0.14);
      --warn: #ffd479;
      --warn-soft: rgba(255,212,121,0.14);
      --bad: #ff8d8d;
      --bad-soft: rgba(255,141,141,0.14);
      --shadow: 0 20px 50px rgba(0,0,0,0.28);
    }

    * { box-sizing: border-box; }
    html, body { margin: 0; padding: 0; }

    body {
      font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      color: var(--text);
      background: var(--bg);
      min-height: 100vh;
    }

    a { color: inherit; text-decoration: none; }

    .app {
      width: min(1120px, calc(100vw - 24px));
      margin: 20px auto 40px;
    }

    .shell {
      background: var(--panel);
      border: 1px solid var(--line);
      box-shadow: var(--shadow);
      border-radius: 28px;
      overflow: hidden;
    }

    .content {
      padding: 18px;
      display: grid;
      gap: 18px;
    }

    .board {
      padding: 18px;
      border: 1px solid var(--line);
      border-radius: 22px;
      background: rgba(255,255,255,0.025);
      display: grid;
      gap: 14px;
    }

    .board-secondary {
      background: rgba(255,255,255,0.02);
    }

    .board-head {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      gap: 12px;
      flex-wrap: wrap;
    }

    .board-eyebrow {
      color: var(--accent);
      text-transform: uppercase;
      letter-spacing: 0.12em;
      font-size: 11px;
      font-weight: 800;
      margin-bottom: 6px;
    }

    .board-title {
      margin: 0;
      font-size: 22px;
      line-height: 1.1;
    }

    .list {
      display: grid;
      gap: 12px;
    }

    .item {
      background: rgba(255,255,255,0.03);
      border: 1px solid var(--line);
      border-radius: 18px;
      overflow: hidden;
    }

    .item-link,
    .item-static {
      display: grid;
      grid-template-columns: 46px minmax(0, 1fr) auto;
      gap: 12px;
      align-items: center;
      padding: 10px 12px;
      min-height: 72px;
    }

    .item-link {
      cursor: pointer;
      transition: transform 0.16s ease, background 0.16s ease;
    }

    .item-link:hover {
      background: rgba(255,255,255,0.035);
      transform: translateY(-1px);
    }

    .item-static {
      opacity: 0.96;
    }

    .poster {
      width: 46px;
      aspect-ratio: 2 / 3;
      border-radius: 12px;
      overflow: hidden;
      background: rgba(255,255,255,0.05);
      border: 1px solid rgba(255,255,255,0.08);
      box-shadow: 0 8px 20px rgba(0,0,0,0.2);
      flex: 0 0 auto;
    }

    .poster img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .poster-fallback {
      width: 100%;
      height: 100%;
      display: grid;
      place-items: center;
      color: rgba(255,255,255,0.4);
      font-size: 11px;
      text-align: center;
      padding: 8px;
    }

    .item-main {
      min-width: 0;
      display: grid;
      gap: 6px;
    }

    .title-block {
      min-width: 0;
      flex: 1 1 auto;
    }

    .title {
      margin: 0;
      font-size: 15px;
      line-height: 1.3;
      font-weight: 800;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    .badges {
      display: flex;
      gap: 8px;
      flex-wrap: nowrap;
      align-items: center;
      justify-content: flex-end;
    }

    .pill {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      border-radius: 999px;
      padding: 7px 10px;
      font-size: 12px;
      font-weight: 800;
      border: 1px solid transparent;
      white-space: nowrap;
    }

    .pill.ok { color: #d8ffef; background: var(--ok-soft); border-color: rgba(74,222,168,0.18); }
    .pill.warn { color: #fff1cc; background: var(--warn-soft); border-color: rgba(255,212,121,0.18); }
    .pill.bad { color: #ffdcdc; background: var(--bad-soft); border-color: rgba(255,141,141,0.18); }
    .pill.info { color: #dbe3ff; background: var(--accent-soft); border-color: rgba(140,158,255,0.2); }

    .chip {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 10px 12px;
      border-radius: 999px;
      background: rgba(255,255,255,0.04);
      border: 1px solid var(--line);
      color: var(--muted);
      font-size: 13px;
    }

    .empty {
      padding: 32px 16px;
      text-align: center;
      color: var(--muted);
      border: 1px dashed rgba(255,255,255,0.1);
      border-radius: 18px;
      background: rgba(255,255,255,0.03);
    }

    .options-panel {
      border-top: 1px solid var(--line);
      background: rgba(255,255,255,0.02);
    }

    .options-summary {
      list-style: none;
      cursor: pointer;
      padding: 14px 18px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      flex-wrap: wrap;
    }

    .options-summary::-webkit-details-marker { display: none; }

    .options-summary::after {
      content: '▾';
      color: var(--muted);
      margin-left: auto;
      order: 3;
      transition: transform 0.16s ease;
    }

    .options-panel[open] .options-summary::after {
      transform: rotate(180deg);
    }

    .options-title {
      font-size: 14px;
      font-weight: 800;
      color: var(--text);
    }

    .options-summary-right {
      display: flex;
      gap: 10px;
      align-items: center;
      flex-wrap: wrap;
    }

    .options-inner {
      padding: 0 18px 18px;
      display: grid;
      gap: 14px;
    }

    .hero {
      padding: 18px;
      border: 1px solid var(--line);
      border-radius: 18px;
      background: var(--panel-soft);
    }

    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      padding: 12px 14px;
      border-radius: 999px;
      background: rgba(255,255,255,0.05);
      border: 1px solid var(--line);
      color: var(--muted);
      font-size: 13px;
      white-space: nowrap;
    }

    .dot {
      width: 10px;
      height: 10px;
      border-radius: 999px;
      background: var(--accent);
      box-shadow: 0 0 0 5px rgba(140,158,255,0.12);
      flex: 0 0 auto;
    }

    .dot.ok { background: var(--ok); box-shadow: 0 0 0 5px rgba(74,222,168,0.12); }
    .dot.warn { background: var(--warn); box-shadow: 0 0 0 5px rgba(255,212,121,0.12); }
    .dot.bad { background: var(--bad); box-shadow: 0 0 0 5px rgba(255,141,141,0.12); }

    .notice {
      margin: 18px 22px 0;
      padding: 14px 16px;
      border-radius: 16px;
      border: 1px solid var(--line);
      background: rgba(255,255,255,0.04);
      color: var(--muted);
      line-height: 1.55;
    }

    .notice.error {
      color: #ffd8d8;
      background: rgba(255,141,141,0.08);
      border-color: rgba(255,141,141,0.18);
    }

    .notice.success {
      color: #d8ffef;
      background: rgba(74,222,168,0.08);
      border-color: rgba(74,222,168,0.18);
    }

    .stats-panel {
      margin-bottom: 18px;
      padding: 0;
      background: rgba(255,255,255,0.035);
      border: 1px solid rgba(255,255,255,0.06);
      border-radius: 18px;
      overflow: hidden;
    }

    .stats-summary {
      list-style: none;
      cursor: pointer;
      padding: 14px 16px;
      font-size: 14px;
      font-weight: 800;
      color: var(--text);
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
    }

    .stats-summary::-webkit-details-marker { display: none; }

    .stats-summary::after {
      content: '▾';
      color: var(--muted);
      transition: transform 0.16s ease;
    }

    .stats-panel[open] .stats-summary::after {
      transform: rotate(180deg);
    }

    .stats {
      display: grid;
      grid-template-columns: repeat(5, minmax(0, 1fr));
      gap: 12px;
      padding: 0 14px 14px;
    }

    .stat {
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.07);
      border-radius: 18px;
      padding: 14px 16px;
      min-height: 96px;
    }

    .stat-label {
      color: var(--muted);
      font-size: 12px;
      margin-bottom: 8px;
    }

    .stat-value {
      font-size: 28px;
      line-height: 1;
      font-weight: 800;
      margin-bottom: 6px;
    }

    .stat-help {
      color: var(--muted);
      font-size: 12px;
      line-height: 1.45;
    }

    .controls {
      display: grid;
      grid-template-columns: repeat(12, minmax(0, 1fr));
      gap: 12px;
      align-items: end;
    }

    .field {
      display: grid;
      gap: 7px;
    }

    .field.username { grid-column: span 3; }
    .field.list { grid-column: span 2; }
    .field.downloaded-list { grid-column: span 2; }
    .field.api { grid-column: span 5; }
    .field.search { grid-column: span 8; }
    .field.actions { grid-column: span 4; }

    label {
      font-size: 12px;
      color: var(--muted);
      font-weight: 700;
    }

    input, button {
      font: inherit;
    }

    input {
      width: 100%;
      color: var(--text);
      background: rgba(255,255,255,0.05);
      border: 1px solid var(--line-strong);
      border-radius: 14px;
      padding: 12px 14px;
      outline: none;
    }

    input:focus {
      border-color: rgba(140,158,255,0.65);
      box-shadow: 0 0 0 4px rgba(140,158,255,0.14);
    }

    .button-row {
      display: flex;
      gap: 10px;
      align-items: center;
      flex-wrap: wrap;
    }

    .primary-btn,
    .ghost-btn {
      min-height: 48px;
      padding: 12px 14px;
      border-radius: 14px;
      font-weight: 800;
      width: 100%;
      border: 0;
      cursor: pointer;
      transition: transform 0.15s ease, opacity 0.15s ease, background 0.15s ease;
    }

    .primary-btn {
      color: white;
      background: linear-gradient(135deg, #8c9eff, #a479ff);
      box-shadow: 0 12px 28px rgba(140,158,255,0.28);
    }

    .ghost-btn {
      color: var(--text);
      background: rgba(255,255,255,0.05);
      border: 1px solid var(--line);
    }

    .primary-btn:hover,
    .ghost-btn:hover {
      transform: translateY(-1px);
    }

    .primary-btn:disabled,
    .ghost-btn:disabled {
      opacity: 0.7;
      cursor: progress;
      transform: none;
    }

    @media (max-width: 920px) {
      .stats { grid-template-columns: repeat(2, minmax(0, 1fr)); }
      .field.username,
      .field.list,
      .field.downloaded-list,
      .field.api,
      .field.search,
      .field.actions { grid-column: span 6; }
    }

    @media (max-width: 680px) {
      .app {
        width: min(100vw - 12px, 1120px);
        margin: 8px auto 18px;
      }

      .shell { border-radius: 22px; }
      .content {
        padding-left: 14px;
        padding-right: 14px;
        padding-top: 14px;
        padding-bottom: 14px;
        gap: 14px;
      }

      .board {
        padding: 14px;
        border-radius: 18px;
      }

      .options-inner { padding: 0 14px 14px; }
      .stats { grid-template-columns: 1fr 1fr; gap: 10px; padding: 0 10px 10px; }
      .stat { padding: 12px; min-height: 0; }
      .stat-value { font-size: 24px; }
      .controls { grid-template-columns: 1fr; }
      .field.username,
      .field.list,
      .field.downloaded-list,
      .field.api,
      .field.search,
      .field.actions { grid-column: auto; }

      .item { border-radius: 16px; }
      .item-link,
      .item-static {
        grid-template-columns: 42px minmax(0, 1fr) auto;
        gap: 10px;
        padding: 10px;
      }

      .poster {
        width: 42px;
        border-radius: 10px;
      }

      .title { font-size: 14px; }
      .button-row { align-items: stretch; }
      .button-row .primary-btn,
      .button-row .ghost-btn { width: 100%; }
      .pill { white-space: normal; }
      .notice { margin-left: 0; margin-right: 0; }
      .options-summary { padding: 12px 14px; }
      .options-summary-right { width: 100%; }
      .options-summary::after { margin-left: 0; }

      .options-summary-right .chip,
      .options-summary-right .hero-badge {
        flex: 1 1 auto;
        justify-content: center;
      }
    }
  </style>
</head>
<body>
  <div class="app">
    <div class="shell">
      <section class="content">
        <section class="board">
          <div class="board-head">
            <div>
              <div class="board-eyebrow">Monitoring</div>
              <h2 class="board-title">Releases</h2>
            </div>
            <span class="chip" id="watchingCountChip">0 titles</span>
          </div>
          <div id="watchingList" class="list"></div>
          <div id="watchingEmpty" class="empty" hidden>No monitored titles yet.</div>
        </section>

        <section class="board board-secondary">
          <div class="board-head">
            <div>
              <div class="board-eyebrow">Library</div>
              <h2 class="board-title">Downloaded</h2>
            </div>
            <span class="chip" id="downloadedCountChip">0 titles</span>
          </div>
          <div id="downloadedList" class="list"></div>
          <div id="downloadedEmpty" class="empty" hidden>No downloaded titles yet.</div>
        </section>
      </section>

      <details class="options-panel" id="optionsPanel">
        <summary class="options-summary">
          <span class="options-title">Options</span>
          <span class="options-summary-right">
            <span class="chip"><strong id="watchingListLabel">zrr / releases</strong></span>
            <span class="chip"><strong id="downloadedListLabel">Downloaded: downloaded</strong></span>
            <span class="chip" id="visibleCountChip">Watching 0 · Downloaded 0</span>
            <span class="hero-badge"><span class="dot" id="statusDot"></span><span id="statusText">Idle</span></span>
          </span>
        </summary>

        <div class="options-inner">
          <div id="notice" class="notice" hidden></div>

          <details class="stats-panel">
            <summary class="stats-summary">Show stats</summary>
            <div class="stats">
              <div class="stat">
                <div class="stat-label">Anime tracked total</div>
                <div class="stat-value" id="statTotal">0</div>
                <div class="stat-help">Combined total from your releases and downloaded AniList lists.</div>
              </div>
              <div class="stat">
                <div class="stat-label">Available now</div>
                <div class="stat-value" id="statFound">0</div>
                <div class="stat-help">Titles in your releases list that are currently on releases.moe.</div>
              </div>
              <div class="stat">
                <div class="stat-label">Already downloaded</div>
                <div class="stat-value" id="statDownloaded">0</div>
                <div class="stat-help">Titles coming from your downloaded AniList custom list.</div>
              </div>
              <div class="stat">
                <div class="stat-label">Still waiting</div>
                <div class="stat-value" id="statWaiting">0</div>
                <div class="stat-help">Titles in your releases list that are not on releases.moe yet.</div>
              </div>
              <div class="stat">
                <div class="stat-label">Last checked</div>
                <div class="stat-value" id="statChecked" style="font-size:18px; line-height:1.2;">Never</div>
                <div class="stat-help">Only refreshes on page load or manual reload.</div>
              </div>
            </div>
          </details>

          <section class="hero" id="settingsPanel">
            <div class="controls">
              <div class="field username">
                <label for="username">AniList username</label>
                <input id="username" value="zrr" autocomplete="off" />
              </div>
              <div class="field list">
                <label for="listName">Releases list name</label>
                <input id="listName" value="releases" autocomplete="off" />
              </div>
              <div class="field downloaded-list">
                <label for="downloadedListName">Downloaded list name</label>
                <input id="downloadedListName" value="downloaded" autocomplete="off" />
              </div>
              <div class="field api">
                <label for="apiBase">releases.moe API base</label>
                <input id="apiBase" value="https://releases.moe" autocomplete="off" />
              </div>
              <div class="field search">
                <label for="searchInput">Filter anime</label>
                <input id="searchInput" placeholder="Search across both boards" autocomplete="off" />
              </div>
              <div class="field actions">
                <label>Actions</label>
                <div class="button-row">
                  <button id="refreshBtn" class="primary-btn">Reload</button>
                  <button id="resetBtn" class="ghost-btn">Reset</button>
                </div>
              </div>
            </div>
          </section>
        </div>
      </details>
    </div>
  </div>

  <script>
    const ANILIST_API = 'https://graphql.anilist.co';
    const STORAGE_KEY = 'releases-watchlist-settings-v5';
    const DEFAULTS = {
      username: 'zrr',
      listName: 'releases',
      downloadedListName: 'downloaded',
      apiBase: 'https://releases.moe'
    };

    const state = {
      items: [],
      lastCheckedAt: null,
      isLoading: false,
      search: ''
    };

    const els = {
      username: document.getElementById('username'),
      listName: document.getElementById('listName'),
      downloadedListName: document.getElementById('downloadedListName'),
      apiBase: document.getElementById('apiBase'),
      searchInput: document.getElementById('searchInput'),
      refreshBtn: document.getElementById('refreshBtn'),
      resetBtn: document.getElementById('resetBtn'),
      statusDot: document.getElementById('statusDot'),
      statusText: document.getElementById('statusText'),
      watchingListLabel: document.getElementById('watchingListLabel'),
      downloadedListLabel: document.getElementById('downloadedListLabel'),
      visibleCountChip: document.getElementById('visibleCountChip'),
      watchingCountChip: document.getElementById('watchingCountChip'),
      downloadedCountChip: document.getElementById('downloadedCountChip'),
      notice: document.getElementById('notice'),
      optionsPanel: document.getElementById('optionsPanel'),
      watchingList: document.getElementById('watchingList'),
      downloadedList: document.getElementById('downloadedList'),
      watchingEmpty: document.getElementById('watchingEmpty'),
      downloadedEmpty: document.getElementById('downloadedEmpty'),
      statTotal: document.getElementById('statTotal'),
      statFound: document.getElementById('statFound'),
      statDownloaded: document.getElementById('statDownloaded'),
      statWaiting: document.getElementById('statWaiting'),
      statChecked: document.getElementById('statChecked')
    };

    function loadSettings() {
      try {
        const raw = localStorage.getItem(STORAGE_KEY);
        if (!raw) return { ...DEFAULTS };
        const parsed = JSON.parse(raw);
        return { ...DEFAULTS, ...parsed };
      } catch {
        return { ...DEFAULTS };
      }
    }

    function getSettings() {
      return {
        username: els.username.value.trim() || DEFAULTS.username,
        listName: els.listName.value.trim() || DEFAULTS.listName,
        downloadedListName: els.downloadedListName.value.trim() || DEFAULTS.downloadedListName,
        apiBase: (els.apiBase.value.trim() || DEFAULTS.apiBase).replace(/\/$/, '')
      };
    }

    function applySettings(settings) {
      els.username.value = settings.username;
      els.listName.value = settings.listName;
      els.downloadedListName.value = settings.downloadedListName;
      els.apiBase.value = settings.apiBase;
      els.watchingListLabel.textContent = `${settings.username} / ${settings.listName}`;
      els.downloadedListLabel.textContent = `Downloaded: ${settings.downloadedListName}`;
    }

    function saveSettings() {
      localStorage.setItem(STORAGE_KEY, JSON.stringify(getSettings()));
    }

    function escapeHtml(value) {
      return String(value ?? '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#039;');
    }

    function setStatus(kind, text) {
      els.statusDot.className = 'dot';
      if (kind) els.statusDot.classList.add(kind);
      els.statusText.textContent = text;
    }

    function showNotice(message, kind = '') {
      els.notice.hidden = false;
      els.notice.className = `notice ${kind}`.trim();
      els.notice.innerHTML = message;
      if (els.optionsPanel) els.optionsPanel.open = true;
    }

    function clearNotice() {
      els.notice.hidden = true;
      els.notice.className = 'notice';
      els.notice.innerHTML = '';
    }

    function formatDateTime(value) {
      if (!value) return 'Never';
      const date = new Date(value);
      if (Number.isNaN(date.getTime())) return '—';
      return new Intl.DateTimeFormat(undefined, {
        year: 'numeric', month: 'short', day: '2-digit',
        hour: '2-digit', minute: '2-digit'
      }).format(date);
    }

    function formatBytes(bytes) {
      const value = Number(bytes);
      if (!Number.isFinite(value) || value <= 0) return '—';
      const units = ['B', 'KB', 'MB', 'GB', 'TB'];
      let n = value;
      let i = 0;
      while (n >= 1024 && i < units.length - 1) {
        n /= 1024;
        i += 1;
      }
      return `${n.toFixed(n >= 100 || i === 0 ? 0 : n >= 10 ? 1 : 2)} ${units[i]}`;
    }

    function normalizeTitle(media) {
      return media?.title?.english || media?.title?.romaji || media?.title?.native || `AniList #${media?.id ?? 'unknown'}`;
    }

    async function postAniList(query, variables) {
      const response = await fetch(ANILIST_API, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify({ query, variables })
      });

      const data = await response.json().catch(() => null);
      if (!response.ok || data?.errors) {
        const message = data?.errors?.[0]?.message || `AniList request failed with ${response.status}`;
        throw new Error(message);
      }
      return data.data;
    }

    async function fetchAniListAnimeLists(username) {
      const query = `
        query ($userName: String!) {
          MediaListCollection(userName: $userName, type: ANIME) {
            lists {
              name
              isCustomList
              entries {
                media {
                  id
                  siteUrl
                  title { romaji english native }
                  coverImage { large color }
                }
              }
            }
          }
        }
      `;

      const data = await postAniList(query, { userName: username });
      return data?.MediaListCollection?.lists || [];
    }

    function getAvailableCustomListNames(lists) {
      return (lists || [])
        .filter((list) => list?.isCustomList)
        .map((list) => list?.name)
        .filter(Boolean);
    }

    function findCustomList(lists, listName) {
      return (lists || []).find((list) =>
        list?.isCustomList &&
        String(list?.name || '').trim().toLowerCase() === String(listName || '').trim().toLowerCase()
      );
    }

    function dedupeMediaList(mediaItems) {
      const deduped = new Map();
      for (const media of mediaItems || []) {
        if (media?.id) deduped.set(media.id, media);
      }
      return Array.from(deduped.values());
    }

    function getRequiredCustomListMedia(lists, listName, username) {
      const wanted = findCustomList(lists, listName);
      if (!wanted) {
        const available = getAvailableCustomListNames(lists);
        const extra = available.length
          ? ` Available custom lists: ${available.map(escapeHtml).join(', ')}.`
          : ' No public custom lists were returned for this account.';
        throw new Error(`Custom list <strong>${escapeHtml(listName)}</strong> was not found for <strong>${escapeHtml(username)}</strong>.${extra}`);
      }
      return dedupeMediaList((wanted.entries || []).map((entry) => entry?.media).filter(Boolean));
    }

    function getOptionalCustomListMedia(lists, listName) {
      if (!String(listName || '').trim()) return [];
      const wanted = findCustomList(lists, listName);
      if (!wanted) return [];
      return dedupeMediaList((wanted.entries || []).map((entry) => entry?.media).filter(Boolean));
    }

    async function fetchAniListLists(username, listName, downloadedListName) {
      const lists = await fetchAniListAnimeLists(username);
      return {
        watching: getRequiredCustomListMedia(lists, listName, username),
        downloaded: getOptionalCustomListMedia(lists, downloadedListName),
        downloadedListExists: Boolean(findCustomList(lists, downloadedListName))
      };
    }

    function chunk(array, size) {
      const out = [];
      for (let i = 0; i < array.length; i += size) out.push(array.slice(i, i + size));
      return out;
    }

    function normalizeLooseString(value) {
      return String(value || '').trim().toLowerCase();
    }

    function getTorrentSignature(torrent) {
      const files = (torrent?.files || [])
        .map((file) => `${file?.name || ''}:${Number(file?.length) || 0}`)
        .sort()
        .join('|');
      const tags = [...(torrent?.tags || [])].map((tag) => normalizeLooseString(tag)).sort().join('|');
      return [
        normalizeLooseString(torrent?.groupedUrl),
        normalizeLooseString(torrent?.infohash),
        normalizeLooseString(torrent?.releaseGroup),
        normalizeLooseString(torrent?.tracker),
        Number(torrent?.dualAudio) ? 'dual' : 'single',
        tags,
        files
      ].join('::');
    }

    function dedupeTorrents(torrents) {
      const byKey = new Map();
      for (const torrent of torrents || []) {
        const strongKey = normalizeLooseString(torrent?.groupedUrl) || normalizeLooseString(torrent?.infohash);
        const fallbackKey = getTorrentSignature(torrent);
        const key = strongKey || fallbackKey;
        const existing = byKey.get(key);
        if (!existing) {
          byKey.set(key, torrent);
          continue;
        }

        const score = (item) => {
          let n = 0;
          if (item?.isBest) n += 100;
          if (item?.dualAudio) n += 20;
          if (item?.url) n += 5;
          if (item?.groupedUrl) n += 5;
          if ((item?.files || []).length) n += 3;
          return n;
        };

        if (score(torrent) > score(existing)) {
          byKey.set(key, torrent);
        }
      }
      return Array.from(byKey.values());
    }

    function choosePreferredEntry(existing, candidate) {
      if (!existing) return candidate;
      const score = (entry) => {
        let n = 0;
        if (!entry?.incomplete) n += 50;
        n += Math.min((entry?.expand?.trs || []).length, 10) * 5;
        n += entry?.comparison ? 5 : 0;
        const updated = Date.parse(entry?.updated || '') || 0;
        n += Math.floor(updated / 1_000_000_000);
        return n;
      };
      return score(candidate) > score(existing) ? candidate : existing;
    }

    function buildSeaDexFilter(ids) {
      return '(' + ids.map((id) => `alID=${Number(id)}`).join(' || ') + ')';
    }

    async function fetchSeaDexByAniListIds(ids, apiBase) {
      if (!ids.length) return new Map();
      const results = [];

      for (const idChunk of chunk(ids, 25)) {
        const params = new URLSearchParams({
          filter: buildSeaDexFilter(idChunk),
          expand: 'trs',
          perPage: String(idChunk.length),
          sort: '-updated'
        });

        const url = `${apiBase}/api/collections/entries/records?${params.toString()}`;
        const response = await fetch(url, { headers: { 'Accept': 'application/json' } });
        const data = await response.json().catch(() => null);
        if (!response.ok) {
          const message = data?.message || `releases.moe request failed with ${response.status}`;
          throw new Error(message);
        }
        results.push(...(data?.items || []));
      }

      const map = new Map();
      for (const item of results) {
        if (item?.alID == null) continue;
        const key = Number(item.alID);
        map.set(key, choosePreferredEntry(map.get(key), item));
      }
      return map;
    }

    function pickBestTorrent(entry) {
      const torrents = dedupeTorrents(entry?.expand?.trs || []);
      if (!torrents.length) return null;
      return [...torrents].sort((a, b) => {
        const score = (torrent) => {
          let n = 0;
          if (torrent?.isBest) n += 100;
          if (torrent?.dualAudio) n += 20;
          if (torrent?.groupedUrl) n += 5;
          if (torrent?.url) n += 2;
          return n;
        };
        return score(b) - score(a);
      })[0];
    }

    function buildViewModel(media, entry, isDownloaded) {
      const bestTorrent = entry ? pickBestTorrent(entry) : null;
      const torrents = dedupeTorrents(entry?.expand?.trs || []);
      const bestSize = bestTorrent
        ? formatBytes((bestTorrent.files || []).reduce((sum, file) => sum + (Number(file?.length) || 0), 0))
        : '—';
      const rawTorrentCount = (entry?.expand?.trs || []).length;
      const duplicateTorrentCount = Math.max(0, rawTorrentCount - torrents.length);

      return {
        id: media.id,
        title: normalizeTitle(media),
        cover: media?.coverImage?.large || '',
        coverColor: media?.coverImage?.color || '#2d3e77',
        aniListUrl: media?.siteUrl || `https://anilist.co/anime/${media.id}`,
        hasSeaDex: Boolean(entry),
        isDownloaded: Boolean(isDownloaded),
        entryUrl: entry ? `https://releases.moe/${media.id}/` : '',
        incomplete: Boolean(entry?.incomplete),
        bestTorrent,
        bestSize,
        torrents,
        rawTorrentCount,
        duplicateTorrentCount,
        searchBlob: [
          normalizeTitle(media),
          entry?.notes || '',
          bestTorrent?.releaseGroup || '',
          (bestTorrent?.tags || []).join(' '),
          isDownloaded ? 'downloaded owned have downloaded' : 'watching monitor waiting releases'
        ].join(' ').toLowerCase()
      };
    }

    function getVisibleItems() {
      const term = state.search.trim().toLowerCase();
      const matches = (item) => !term || item.searchBlob.includes(term);
      return {
        watching: state.items.filter((item) => !item.isDownloaded && matches(item)),
        downloaded: state.items.filter((item) => item.isDownloaded && matches(item))
      };
    }

    function renderItemInto(container, item) {
      const article = document.createElement('article');
      article.className = 'item';

      const poster = item.cover
        ? `<img src="${escapeHtml(item.cover)}" alt="${escapeHtml(item.title)} cover" loading="lazy" />`
        : `<div class="poster-fallback" style="background:${escapeHtml(item.coverColor)}22;">No cover</div>`;

      let statusClass = 'bad';
      let statusText = 'Waiting';
      if (item.isDownloaded) {
        statusClass = 'info';
        statusText = 'Downloaded';
      } else if (item.hasSeaDex && item.incomplete) {
        statusClass = 'warn';
        statusText = 'Incomplete';
      } else if (item.hasSeaDex) {
        statusClass = 'ok';
        statusText = 'Available';
      }

      const cardInner = `
        <div class="poster">${poster}</div>
        <div class="item-main">
          <div class="title-block">
            <h2 class="title">${escapeHtml(item.title)}</h2>
          </div>
        </div>
        <div class="badges">
          <span class="pill ${statusClass}">${statusText}</span>
        </div>
      `;

      if (item.hasSeaDex && item.entryUrl) {
        article.innerHTML = `
          <a
            class="item-link"
            href="${escapeHtml(item.entryUrl)}"
            target="_blank"
            rel="noreferrer"
            aria-label="Open ${escapeHtml(item.title)} on releases.moe"
            title="Open on releases.moe"
          >
            ${cardInner}
          </a>
        `;
      } else {
        article.innerHTML = `
          <div class="item-static" aria-disabled="true" title="No releases.moe page yet">
            ${cardInner}
          </div>
        `;
      }

      container.appendChild(article);
    }

    function render() {
      const visible = getVisibleItems();
      const watchingItems = visible.watching;
      const downloadedItems = visible.downloaded;
      const total = state.items.length;
      const downloadedCount = state.items.filter((item) => item.isDownloaded).length;
      const foundCount = state.items.filter((item) => !item.isDownloaded && item.hasSeaDex).length;
      const waitingCount = state.items.filter((item) => !item.isDownloaded && !item.hasSeaDex).length;

      els.watchingList.innerHTML = '';
      els.downloadedList.innerHTML = '';
      els.watchingEmpty.hidden = watchingItems.length > 0;
      els.downloadedEmpty.hidden = downloadedItems.length > 0;
      els.statTotal.textContent = String(total);
      els.statFound.textContent = String(foundCount);
      els.statDownloaded.textContent = String(downloadedCount);
      els.statWaiting.textContent = String(waitingCount);
      els.statChecked.textContent = state.lastCheckedAt ? formatDateTime(state.lastCheckedAt) : 'Never';
      els.visibleCountChip.textContent = `Watching ${watchingItems.length} · Downloaded ${downloadedItems.length}`;
      els.watchingCountChip.textContent = `${watchingItems.length} title${watchingItems.length === 1 ? '' : 's'}`;
      els.downloadedCountChip.textContent = `${downloadedItems.length} title${downloadedItems.length === 1 ? '' : 's'}`;

      watchingItems.forEach((item) => renderItemInto(els.watchingList, item));
      downloadedItems.forEach((item) => renderItemInto(els.downloadedList, item));
    }

    async function runRefresh(showSuccess = true) {
      if (state.isLoading) return;
      const settings = getSettings();
      saveSettings();
      applySettings(settings);
      state.isLoading = true;
      els.refreshBtn.disabled = true;
      setStatus('', 'Refreshing…');
      clearNotice();

      try {
        const { watching, downloaded, downloadedListExists } = await fetchAniListLists(
          settings.username,
          settings.listName,
          settings.downloadedListName
        );

        const watchingIds = new Set(watching.map((media) => Number(media.id)));
        const downloadedOnly = downloaded.filter((media) => !watchingIds.has(Number(media.id)));
        const allMedia = [...watching, ...downloadedOnly];
        const seaDexMap = await fetchSeaDexByAniListIds(allMedia.map((media) => media.id), settings.apiBase);

        state.items = allMedia
          .map((media) => buildViewModel(media, seaDexMap.get(media.id) || null, !watchingIds.has(Number(media.id))))
          .sort((a, b) => {
            const rank = (item) => {
              if (item.isDownloaded) return 2;
              if (item.hasSeaDex) return 1;
              return 0;
            };
            return rank(b) - rank(a) || a.title.localeCompare(b.title);
          });

        state.lastCheckedAt = new Date();
        setStatus('ok', 'Ready');
        render();

        if (showSuccess) {
          const downloadedCount = state.items.filter((item) => item.isDownloaded).length;
          const foundCount = state.items.filter((item) => !item.isDownloaded && item.hasSeaDex).length;
          const waitingCount = state.items.filter((item) => !item.isDownloaded && !item.hasSeaDex).length;
          const downloadedListNote = downloadedListExists
            ? ` <strong>${downloadedCount}</strong> ${downloadedCount === 1 ? 'title is' : 'titles are'} shown in <strong>${escapeHtml(settings.downloadedListName)}</strong>.`
            : ` The downloaded list <strong>${escapeHtml(settings.downloadedListName)}</strong> was not found, so nothing was shown in Downloaded.`;

          showNotice(
            `Loaded <strong>${state.items.length}</strong> total anime from your two lists. ` +
            `<strong>${watching.length}</strong> ${watching.length === 1 ? 'title is' : 'titles are'} being monitored in <strong>${escapeHtml(settings.listName)}</strong>. ` +
            `<strong>${foundCount}</strong> ${foundCount === 1 ? 'title is' : 'titles are'} currently available and <strong>${waitingCount}</strong> ${waitingCount === 1 ? 'title is' : 'titles are'} still waiting.` +
            downloadedListNote,
            'success'
          );
        } else if (els.optionsPanel) {
          els.optionsPanel.open = false;
        }
      } catch (error) {
        setStatus('bad', 'Error');
        const message = error instanceof Error ? error.message : String(error);
        showNotice(
          `Refresh failed. ${message}<br><br>` +
          `If AniList works but releases.moe is blocked in your browser, the next step is a tiny proxy in front of the releases.moe API and pointing the API base field at that proxy.`,
          'error'
        );
      } finally {
        state.isLoading = false;
        els.refreshBtn.disabled = false;
      }
    }

    function resetDefaults() {
      applySettings(DEFAULTS);
      state.search = '';
      els.searchInput.value = '';
      saveSettings();
      runRefresh(true);
    }

    function init() {
      applySettings(loadSettings());

      els.refreshBtn.addEventListener('click', () => runRefresh(true));
      els.resetBtn.addEventListener('click', resetDefaults);
      els.searchInput.addEventListener('input', (event) => {
        state.search = event.target.value || '';
        render();
      });

      [els.username, els.listName, els.downloadedListName, els.apiBase].forEach((el) => {
        el.addEventListener('change', () => {
          saveSettings();
          applySettings(getSettings());
        });
      });

      render();
      runRefresh(false);
    }

    init();
  </script>
</body>
