<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AutoBrr Filter Gen</title>
    <style>
        :root { --primary: #3e5cf4; --bg: #f8f9fa; --card-bg: #ffffff; --border: #eee; --muted: #666; --danger: #dc3545; --success: #28a745; }
        body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif; background: var(--bg); display: flex; justify-content: center; padding: 40px 20px; margin: 0; }
        .card { background: var(--card-bg); width: 100%; max-width: 900px; padding: 30px; border-radius: 16px; box-shadow: 0 10px 25px rgba(0,0,0,0.05); box-sizing: border-box; }
        h1 { margin-top: 0; }
        .input-group { display: flex; gap: 10px; margin-bottom: 14px; }
        input[type="text"] { flex-grow: 1; padding: 12px; border: 2px solid var(--border); border-radius: 8px; font-size: 16px; outline: none; min-width: 0; }
        input[type="text"]:focus { border-color: var(--primary); }
        button { padding: 12px 24px; cursor: pointer; background: var(--primary); color: white; border: none; border-radius: 8px; font-weight: 600; transition: opacity 0.2s; white-space: nowrap; }
        button:disabled { opacity: 0.6; cursor: not-allowed; }
        .button-row { display: flex; gap: 10px; margin-top: 10px; }
        #copyBtn { background: var(--success); flex: 1; display: none; }
        #clearCacheBtn { background: #111827; }
        textarea { width: 100%; height: 350px; margin-top: 15px; padding: 15px; border: 1px solid #ddd; border-radius: 8px; font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace; font-size: 13px; background: #fafafa; box-sizing: border-box; resize: vertical; }
        .status { font-size: 13px; font-weight: 600; margin-bottom: 10px; min-height: 20px; }
        .error { color: var(--danger); }
        .success { color: var(--success); }
        .hint { color: var(--muted); font-size: 12px; line-height: 1.4; margin: 8px 0 0; }
        .options { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 8px; margin-bottom: 14px; }
        .option { display: flex; gap: 8px; align-items: flex-start; border: 1px solid var(--border); border-radius: 8px; padding: 10px; background: #fafafa; font-size: 13px; line-height: 1.35; }
        .option input { margin-top: 2px; }
        .option strong { display: block; }
        .option span { color: var(--muted); }
        .progress-wrap { display: none; height: 8px; background: #e9ecef; border-radius: 999px; overflow: hidden; margin: 8px 0 12px; }
        .progress-bar { height: 100%; width: 0%; background: var(--primary); transition: width 0.2s ease; }
        .log { display: none; margin-top: 12px; max-height: 220px; overflow: auto; border: 1px solid #ddd; border-radius: 8px; background: #fff; }
        .log-line { padding: 7px 10px; border-bottom: 1px solid #eee; font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace; font-size: 12px; line-height: 1.35; }
        .log-line:last-child { border-bottom: 0; }
        .log-ok { color: var(--success); }
        .log-warn { color: #b45309; }
        .log-error { color: var(--danger); }
        @media (max-width: 700px) {
            .input-group, .button-row { flex-direction: column; }
            .options { grid-template-columns: 1fr; }
            button { width: 100%; }
        }
    </style>
</head>
<body>

<div class="card">
    <h1>AniList -> AutoBrr</h1>
    <div class="input-group">
        <input type="text" id="username" placeholder="AniList Username" autocomplete="username">
        <button id="generateBtn" onclick="generateFilter()">Generate</button>
    </div>

    <div class="options">
        <label class="option">
            <input type="checkbox" id="useJikan" checked>
            <div><strong>Enrich with MAL/Jikan</strong><span>Uses exact MAL IDs from AniList first, then fuzzy search only if needed.</span></div>
        </label>
        <label class="option">
            <input type="checkbox" id="includeNative">
            <div><strong>Include native / non-ASCII titles</strong><span>Off by default because the wildcard tokenizer is ASCII-focused.</span></div>
        </label>
        <label class="option">
            <input type="checkbox" id="shortDescriptorVariants" checked>
            <div><strong>Add shortened Arc/Saga variants</strong><span>Also tries titles that drop trailing Arc, Saga, Chapter, Hen, Movie, or Film.</span></div>
        </label>
        <label class="option">
            <input type="checkbox" id="showLog" checked>
            <div><strong>Show Jikan log</strong><span>Displays accepted, skipped, cached, and failed MAL/Jikan lookups.</span></div>
        </label>
    </div>

    <div id="status" class="status"></div>
    <div id="progressWrap" class="progress-wrap"><div id="progressBar" class="progress-bar"></div></div>

    <textarea id="output" readonly placeholder="Filter will appear here..."></textarea>
    <div class="button-row">
        <button id="copyBtn" onclick="copyToClipboard()">Copy to Clipboard</button>
        <button id="clearCacheBtn" onclick="clearJikanCache()">Clear Jikan Cache</button>
    </div>
    <p class="hint">Only AniList entries with status CURRENT are included. Very short titles are emitted exactly instead of as broad wildcards. Jikan/MAL enrichment is cached locally for 7 days.</p>
    <div id="log" class="log"></div>
</div>

<script>
    const ANILIST_API_URL = "https://graphql.anilist.co";
    const JIKAN_API_URL = "https://api.jikan.moe/v4";
    const JIKAN_DELAY_MS = 1200;
    const JIKAN_CACHE_TTL_MS = 7 * 24 * 60 * 60 * 1000;
    const JIKAN_FUZZY_ACCEPT_SCORE = 70;

    let lastJikanRequestAt = 0;

    function safeGetItem(key) {
        try {
            return localStorage.getItem(key);
        } catch {
            return null;
        }
    }

    function safeSetItem(key, value) {
        try {
            localStorage.setItem(key, value);
        } catch {
            // Ignore locked-down/private-browser storage failures.
        }
    }

    function safeRemoveItem(key) {
        try {
            localStorage.removeItem(key);
        } catch {
            // Ignore locked-down/private-browser storage failures.
        }
    }

    function sleep(ms) {
        return new Promise(resolve => setTimeout(resolve, ms));
    }

    function isEnglishFriendly(value) {
        return /^[\x00-\x7F]*$/.test(String(value || ""));
    }

    function foldCommonCharacters(value) {
        return String(value)
            .normalize("NFKD")
            .replace(/[\u0300-\u036f]/g, "")
            .replace(/[×✕✖]/g, " x ")
            .replace(/&/g, " and ")
            .replace(/\+/g, " plus ")
            .replace(/½/g, " 1 2 ")
            .replace(/[‐‑‒–—―]/g, "-");
    }

    function getTitleTokens(title) {
        return foldCommonCharacters(title)
            .toLowerCase()
            .match(/[a-z0-9]+/g) || [];
    }

    function toWildcardPattern(title) {
        const tokens = getTitleTokens(title);
        if (!tokens.length) return "";
        return tokens.join("*");
    }

    function normalizeForCompare(title) {
        return getTitleTokens(title).join(" ");
    }

    function compactForCompare(title) {
        return getTitleTokens(title).join("");
    }

    function uniqueTitles(rawTitles) {
        const seen = new Set();
        const unique = [];

        rawTitles
            .filter(Boolean)
            .map(title => String(title).trim())
            .filter(Boolean)
            .forEach(title => {
                const key = title.toLowerCase();
                if (seen.has(key)) return;
                seen.add(key);
                unique.push(title);
            });

        return unique;
    }

    function ordinalSuffix(n) {
        const num = Number(n);
        const mod100 = num % 100;
        if (mod100 >= 11 && mod100 <= 13) return `${num}th`;

        switch (num % 10) {
            case 1: return `${num}st`;
            case 2: return `${num}nd`;
            case 3: return `${num}rd`;
            default: return `${num}th`;
        }
    }

    function ordinalWord(n) {
        return {
            1: "first",
            2: "second",
            3: "third",
            4: "fourth",
            5: "fifth",
            6: "sixth",
            7: "seventh",
            8: "eighth",
            9: "ninth",
            10: "tenth"
        }[Number(n)] || null;
    }

    function romanNumeral(n) {
        return {
            1: "i",
            2: "ii",
            3: "iii",
            4: "iv",
            5: "v",
            6: "vi",
            7: "vii",
            8: "viii",
            9: "ix",
            10: "x"
        }[Number(n)] || null;
    }

    function stripTrailingSeparators(value) {
        return value
            .replace(/[\s:;,\.\-–—_]+$/g, "")
            .replace(/^[\s:;,\.\-–—_]+/g, "")
            .trim();
    }

    function expandBasicTitleVariants(title) {
        const variants = new Set();
        const original = String(title).trim();
        if (!original) return variants;

        variants.add(original);
        variants.add(original.replace(/[’'`´]/g, ""));
        variants.add(original.replace(/\s*&\s*/g, " and "));
        variants.add(original.replace(/\s*&\s*/g, " "));
        variants.add(original.replace(/^(the|a|an)\s+/i, ""));

        return new Set([...variants].map(v => v.trim()).filter(Boolean));
    }

    function getSeasonInfo(title) {
        const folded = foldCommonCharacters(title).toLowerCase();

        const match =
            folded.match(/\b(?:season|part|cour)\s*0*(\d+)\b/i) ||
            folded.match(/\b0*(\d+)(?:st|nd|rd|th)\s+(?:season|part|cour)\b/i) ||
            folded.match(/\bs0*(\d+)\b/i);

        if (!match) return null;

        const n = Number(match[1]);
        if (!Number.isInteger(n) || n < 1 || n > 99) return null;

        const rootTitle = stripTrailingSeparators(
            String(title)
                .replace(/\b(?:season|part|cour)\s*0*\d+\b/ig, "")
                .replace(/\b0*\d+(?:st|nd|rd|th)\s+(?:season|part|cour)\b/ig, "")
                .replace(/\bs0*\d+\b/ig, "")
        );

        if (!rootTitle) return null;
        return { rootTitle, n };
    }

    function expandSeasonVariants(title) {
        const info = getSeasonInfo(title);
        if (!info) return new Set();

        const { rootTitle, n } = info;
        const padded = String(n).padStart(2, "0");
        const ordinal = ordinalSuffix(n);
        const ordinalAsWord = ordinalWord(n);
        const roman = romanNumeral(n);

        const variants = new Set([
            `${rootTitle} ${n}`,
            `${rootTitle} ${ordinal} season`,
            `${rootTitle} season ${n}`,
            `${rootTitle} part ${n}`,
            `${rootTitle} cour ${n}`,
            `${rootTitle} s${n}`,
            `${rootTitle} s${padded}`
        ]);

        if (ordinalAsWord) variants.add(`${rootTitle} ${ordinalAsWord} season`);
        if (roman) {
            variants.add(`${rootTitle} ${roman}`);
            variants.add(`${rootTitle} season ${roman}`);
            variants.add(`${rootTitle} part ${roman}`);
        }

        return new Set([...variants].map(v => v.trim()).filter(Boolean));
    }

    function expandTrailingDescriptorVariants(title) {
        const variants = new Set();
        const original = String(title).trim();
        if (!original) return variants;

        variants.add(original);

        const shortened = original
            .replace(/\s+(arc|hen|saga|chapter|story|movie|film)$/i, "")
            .trim();

        if (shortened !== original && compactForCompare(shortened).length >= 8) {
            variants.add(shortened);
        }

        return variants;
    }

    function expandAllTitleVariants(title, options) {
        const variants = new Set();
        const descriptorVariants = options.shortDescriptorVariants
            ? expandTrailingDescriptorVariants(title)
            : new Set([String(title).trim()].filter(Boolean));

        descriptorVariants.forEach(descriptorVariant => {
            expandBasicTitleVariants(descriptorVariant).forEach(v => variants.add(v));
            expandSeasonVariants(descriptorVariant).forEach(v => {
                expandBasicTitleVariants(v).forEach(basic => variants.add(basic));
            });
        });

        return variants;
    }

    function addPattern(patterns, rawPattern) {
        const pattern = String(rawPattern || "").trim();
        if (!pattern) return;

        const compactLength = pattern.replace(/[\?\*]/g, "").length;
        const containsWildcard = /[\?\*]/.test(pattern);

        if (compactLength === 0) return;

        if (compactLength <= 2 && !containsWildcard) {
            patterns.add(pattern);
            return;
        }

        if (compactLength <= 2) return;

        patterns.add(`*${pattern}*`);
    }

    function generatePatternsForTitle(title, options) {
        const patterns = new Set();

        expandAllTitleVariants(title, options).forEach(variant => {
            addPattern(patterns, toWildcardPattern(variant));
        });

        return patterns;
    }

    function collectTitles(media, options) {
        const rawTitles = [
            media?.title?.romaji,
            media?.title?.english,
            media?.title?.userPreferred,
            ...(options.includeNative ? [media?.title?.native] : []),
            ...(Array.isArray(media?.synonyms) ? media.synonyms : [])
        ];

        const titles = uniqueTitles(rawTitles);
        return options.includeNative ? titles : titles.filter(isEnglishFriendly);
    }

    function collectJikanTitles(item, options) {
        const rawTitles = [
            item?.title,
            item?.title_english,
            ...(options.includeNative ? [item?.title_japanese] : []),
            ...(Array.isArray(item?.title_synonyms) ? item.title_synonyms : []),
            ...(Array.isArray(item?.titles) ? item.titles.map(title => title?.title) : [])
        ];

        const titles = uniqueTitles(rawTitles);
        return options.includeNative ? titles : titles.filter(isEnglishFriendly);
    }

    function sortPatterns(patterns) {
        return [...patterns].sort((a, b) => {
            const cleanA = a.replace(/^\*/, "").replace(/\*$/, "");
            const cleanB = b.replace(/^\*/, "").replace(/\*$/, "");
            return cleanA.localeCompare(cleanB) || a.localeCompare(b);
        });
    }

    function setStatus(message, type = "") {
        const status = document.getElementById("status");
        status.innerText = message;
        status.className = `status ${type}`.trim();
    }

    function setProgress(done, total) {
        const wrap = document.getElementById("progressWrap");
        const bar = document.getElementById("progressBar");

        if (!total) {
            wrap.style.display = "none";
            bar.style.width = "0%";
            return;
        }

        wrap.style.display = "block";
        bar.style.width = `${Math.round((done / total) * 100)}%`;
    }

    function logLine(message, type = "") {
        if (!document.getElementById("showLog").checked) return;

        const log = document.getElementById("log");
        log.style.display = "block";

        const line = document.createElement("div");
        line.className = `log-line ${type ? `log-${type}` : ""}`.trim();
        line.textContent = message;
        log.appendChild(line);
        log.scrollTop = log.scrollHeight;
    }

    function resetLog() {
        const log = document.getElementById("log");
        log.innerHTML = "";
        log.style.display = document.getElementById("showLog").checked ? "block" : "none";
    }

    function jikanCacheGet(key) {
        const raw = safeGetItem(key);
        if (!raw) return null;

        try {
            const cached = JSON.parse(raw);
            if (!cached || Date.now() - cached.savedAt > JIKAN_CACHE_TTL_MS) {
                safeRemoveItem(key);
                return null;
            }
            return cached.value;
        } catch {
            safeRemoveItem(key);
            return null;
        }
    }

    function jikanCacheSet(key, value) {
        safeSetItem(key, JSON.stringify({ savedAt: Date.now(), value }));
    }

    async function throttledJikanFetch(url) {
        const elapsed = Date.now() - lastJikanRequestAt;
        if (elapsed < JIKAN_DELAY_MS) await sleep(JIKAN_DELAY_MS - elapsed);

        lastJikanRequestAt = Date.now();

        const response = await fetch(url, { headers: { "Accept": "application/json" } });

        let result;
        try {
            result = await response.json();
        } catch {
            throw new Error(`Jikan returned a non-JSON response. HTTP ${response.status}.`);
        }

        if (!response.ok) {
            const message = result?.message || result?.error || `Jikan returned HTTP ${response.status}.`;
            throw new Error(message);
        }

        return result;
    }

    async function getJikanAnimeByMalId(malId) {
        const cacheKey = `autobrr_jikan_mal_${malId}`;
        const cached = jikanCacheGet(cacheKey);
        if (cached) return { item: cached, fromCache: true };

        const result = await throttledJikanFetch(`${JIKAN_API_URL}/anime/${encodeURIComponent(malId)}`);
        const item = result?.data || null;

        if (item) jikanCacheSet(cacheKey, item);
        return { item, fromCache: false };
    }

    async function searchJikanAnime(searchTerm) {
        const normalizedTerm = normalizeForCompare(searchTerm);
        const cacheKey = `autobrr_jikan_search_${normalizedTerm}`;
        const cached = jikanCacheGet(cacheKey);
        if (cached) return { items: cached, fromCache: true };

        const url = `${JIKAN_API_URL}/anime?q=${encodeURIComponent(searchTerm)}&limit=5`;
        const result = await throttledJikanFetch(url);
        const items = Array.isArray(result?.data) ? result.data : [];

        jikanCacheSet(cacheKey, items);
        return { items, fromCache: false };
    }

    function tokenOverlapScore(a, b) {
        const aTokens = new Set(getTitleTokens(a));
        const bTokens = new Set(getTitleTokens(b));

        if (!aTokens.size || !bTokens.size) return 0;

        let overlap = 0;
        aTokens.forEach(token => {
            if (bTokens.has(token)) overlap++;
        });

        const smallerCoverage = overlap / Math.min(aTokens.size, bTokens.size);
        const largerCoverage = overlap / Math.max(aTokens.size, bTokens.size);

        return Math.round((smallerCoverage * 60) + (largerCoverage * 30));
    }

    function yearFromJikan(item) {
        return item?.year || item?.aired?.prop?.from?.year || null;
    }

    function scoreJikanCandidate(anilistTitles, jikanItem, media, options) {
        const jikanTitles = collectJikanTitles(jikanItem, options);
        const aniNormalized = anilistTitles.map(normalizeForCompare).filter(Boolean);
        const jikanNormalized = jikanTitles.map(normalizeForCompare).filter(Boolean);
        const aniCompact = anilistTitles.map(compactForCompare).filter(Boolean);
        const jikanCompact = jikanTitles.map(compactForCompare).filter(Boolean);

        let best = 0;

        for (const aniTitle of aniNormalized) {
            for (const jikanTitle of jikanNormalized) {
                if (aniTitle === jikanTitle) best = Math.max(best, 100);
                else if (aniTitle.includes(jikanTitle) || jikanTitle.includes(aniTitle)) best = Math.max(best, 85);
                else best = Math.max(best, tokenOverlapScore(aniTitle, jikanTitle));
            }
        }

        for (const aniTitle of aniCompact) {
            for (const jikanTitle of jikanCompact) {
                if (aniTitle && aniTitle === jikanTitle) best = Math.max(best, 96);
            }
        }

        const aniYear = media?.startDate?.year || null;
        const jikanYear = yearFromJikan(jikanItem);

        if (aniYear && jikanYear) {
            if (aniYear === jikanYear) best += 5;
            else if (Math.abs(aniYear - jikanYear) >= 2) best -= 12;
        }

        return Math.max(0, Math.min(100, best));
    }

    function bestJikanSearchTerm(media, anilistTitles) {
        return media?.title?.english
            || media?.title?.romaji
            || media?.title?.userPreferred
            || anilistTitles.find(isEnglishFriendly)
            || anilistTitles[0]
            || "";
    }

    async function getJikanTitlesForMedia(media, anilistTitles, options) {
        if (media?.idMal) {
            const { item, fromCache } = await getJikanAnimeByMalId(media.idMal);
            const titles = item ? collectJikanTitles(item, options) : [];

            logLine(`${media?.title?.userPreferred || media?.title?.romaji || media.id}: exact MAL ID ${media.idMal}${fromCache ? " from cache" : ""}; ${titles.length} Jikan title(s).`, "ok");
            return titles;
        }

        const searchTerm = bestJikanSearchTerm(media, anilistTitles);
        if (!searchTerm) {
            logLine(`${media?.id}: skipped Jikan search; no usable search title.`, "warn");
            return [];
        }

        const { items, fromCache } = await searchJikanAnime(searchTerm);
        if (!items.length) {
            logLine(`${searchTerm}: no Jikan search results${fromCache ? " from cache" : ""}.`, "warn");
            return [];
        }

        const best = items
            .map(item => ({ item, score: scoreJikanCandidate(anilistTitles, item, media, options) }))
            .sort((a, b) => b.score - a.score)[0];

        if (!best || best.score < JIKAN_FUZZY_ACCEPT_SCORE) {
            logLine(`${searchTerm}: skipped fuzzy Jikan match; best score ${best?.score || 0}.`, "warn");
            return [];
        }

        const titles = collectJikanTitles(best.item, options);
        logLine(`${searchTerm}: accepted fuzzy Jikan match MAL ${best.item?.mal_id || "unknown"} with score ${best.score}${fromCache ? " from cache" : ""}; ${titles.length} Jikan title(s).`, "ok");
        return titles;
    }

    function clearJikanCache() {
        let removed = 0;

        try {
            for (let i = localStorage.length - 1; i >= 0; i--) {
                const key = localStorage.key(i);
                if (key && key.startsWith("autobrr_jikan_")) {
                    localStorage.removeItem(key);
                    removed++;
                }
            }
        } catch {
            setStatus("Could not clear Jikan cache. Browser storage may be unavailable.", "error");
            return;
        }

        setStatus(`Cleared ${removed} cached Jikan entr${removed === 1 ? "y" : "ies"}.`, "success");
    }

    document.addEventListener("DOMContentLoaded", () => {
        const usernameInput = document.getElementById("username");
        const savedName = safeGetItem("anilist_username");

        if (savedName) usernameInput.value = savedName;

        usernameInput.addEventListener("keydown", event => {
            if (event.key === "Enter") generateFilter();
        });
    });

    async function generateFilter() {
        const usernameInput = document.getElementById("username");
        const username = usernameInput.value.trim();
        const output = document.getElementById("output");
        const copyBtn = document.getElementById("copyBtn");
        const generateBtn = document.getElementById("generateBtn");
        const clearCacheBtn = document.getElementById("clearCacheBtn");

        if (!username) {
            setStatus("Enter an AniList username.", "error");
            return;
        }

        const options = {
            useJikan: document.getElementById("useJikan").checked,
            includeNative: document.getElementById("includeNative").checked,
            shortDescriptorVariants: document.getElementById("shortDescriptorVariants").checked
        };

        safeSetItem("anilist_username", username);
        generateBtn.disabled = true;
        clearCacheBtn.disabled = true;
        setStatus("Querying AniList...");
        setProgress(0, 0);
        resetLog();
        output.value = "";
        copyBtn.style.display = "none";

        const query = `
        query ($name: String) {
          MediaListCollection(userName: $name, type: ANIME, status: CURRENT) {
            lists {
              entries {
                media {
                  id
                  idMal
                  format
                  startDate { year month day }
                  title { romaji english native userPreferred }
                  synonyms
                }
              }
            }
          }
        }`;

        try {
            const response = await fetch(ANILIST_API_URL, {
                method: "POST",
                headers: {
                    "Content-Type": "application/json",
                    "Accept": "application/json"
                },
                body: JSON.stringify({ query, variables: { name: username } })
            });

            let result;
            try {
                result = await response.json();
            } catch {
                throw new Error(`AniList returned a non-JSON response. HTTP ${response.status}.`);
            }

            if (!response.ok) {
                const retryAfter = response.headers.get("Retry-After");
                const apiMessage = result?.errors?.map(error => error.message).join("; ");
                let message = apiMessage || `AniList returned HTTP ${response.status}.`;

                if (response.status === 429 && retryAfter) {
                    message += ` Retry after ${retryAfter} seconds.`;
                }

                throw new Error(message);
            }

            if (result.errors?.length) {
                throw new Error(result.errors.map(error => error.message).join("; "));
            }

            const collection = result?.data?.MediaListCollection;
            if (!collection) throw new Error("User not found or list is private.");

            const lists = Array.isArray(collection.lists) ? collection.lists : [];
            const seenMediaIds = new Set();
            const currentMedia = [];

            lists.forEach(list => {
                const entries = Array.isArray(list.entries) ? list.entries : [];

                entries.forEach(entry => {
                    const media = entry?.media;
                    if (!media?.id || seenMediaIds.has(media.id)) return;

                    seenMediaIds.add(media.id);
                    currentMedia.push(media);
                });
            });

            if (currentMedia.length === 0) {
                throw new Error("No CURRENT anime were found on this AniList account.");
            }

            const allPatterns = new Set();
            let jikanAddedTitleCount = 0;
            let jikanErrorCount = 0;

            setProgress(0, currentMedia.length);

            for (let i = 0; i < currentMedia.length; i++) {
                const media = currentMedia[i];
                const displayTitle = media?.title?.userPreferred || media?.title?.english || media?.title?.romaji || `AniList ID ${media.id}`;

                setStatus(`${options.useJikan ? "Enriching with Jikan/MAL" : "Generating patterns"} ${i + 1}/${currentMedia.length}: ${displayTitle}`);

                const anilistTitles = collectTitles(media, options);
                let combinedTitles = [...anilistTitles];

                if (options.useJikan) {
                    try {
                        const jikanTitles = await getJikanTitlesForMedia(media, anilistTitles, options);
                        const before = uniqueTitles(combinedTitles).length;
                        combinedTitles = uniqueTitles([...combinedTitles, ...jikanTitles]);
                        jikanAddedTitleCount += Math.max(0, combinedTitles.length - before);
                    } catch (error) {
                        console.warn(`Jikan failed for ${displayTitle}:`, error);
                        logLine(`${displayTitle}: Jikan failed: ${error?.message || "Unknown error."}`, "error");
                        jikanErrorCount++;
                    }
                }

                combinedTitles.forEach(title => {
                    generatePatternsForTitle(title, options).forEach(pattern => allPatterns.add(pattern));
                });

                setProgress(i + 1, currentMedia.length);
            }

            const finalPatterns = sortPatterns(allPatterns);

            if (finalPatterns.length === 0) {
                throw new Error("No usable title patterns were generated. Refusing to output an empty AutoBrr filter.");
            }

            const finalOutput = finalPatterns.join(",");
            const charCount = finalOutput.length.toLocaleString();

            output.value = finalOutput;

            let message = `Generated ${finalPatterns.length} unique patterns from ${seenMediaIds.size} current shows. `;
            if (options.useJikan) message += `Added ${jikanAddedTitleCount} MAL/Jikan titles. `;
            message += `${charCount} characters.`;

            if (jikanErrorCount > 0) {
                message += ` Jikan failed for ${jikanErrorCount} show${jikanErrorCount === 1 ? "" : "s"}, but AniList patterns were still generated.`;
            }

            if (finalOutput.length > 500000) {
                message += " Warning: this is very large and may fail to save behind some reverse proxies.";
            }

            setStatus(message, "success");
            copyBtn.style.display = "block";
        } catch (err) {
            setStatus("Error: " + (err?.message || "Unknown error."), "error");
        } finally {
            generateBtn.disabled = false;
            clearCacheBtn.disabled = false;
            setProgress(0, 0);
        }
    }

    async function copyToClipboard() {
        const output = document.getElementById("output");
        const btn = document.getElementById("copyBtn");

        try {
            if (!navigator.clipboard?.writeText) throw new Error("Clipboard API unavailable.");
            await navigator.clipboard.writeText(output.value);
        } catch {
            output.focus();
            output.select();
            document.execCommand("copy");
            output.setSelectionRange(0, 0);
        }

        btn.innerText = "Copied!";
        setTimeout(() => {
            btn.innerText = "Copy to Clipboard";
        }, 2000);
    }
</script>
